# MongoDB connection
MONGODB_URI=your_mongodb_connection_string

# JWT secret
JWT_SECRET=your_jwt_secret

# ImageKit
IMAGEKIT_PUBLIC_KEY=your_imagekit_public
IMAGEKIT_PRIVATE_KEY=your_imagekit_private
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_endpoint

# Brevo (Sendinblue) API
# Add your Brevo API key here (recommended: store in deployment secret manager)
BREVO_API_KEY=your_brevo_api_key
# Optional: override API URL if needed
BREVO_API_URL=https://api.brevo.com/v3/smtp/email

# SMTP fallback (optional)
# If you want to enable SMTP fallback, set these credentials (do NOT commit real creds)
EMAIL_USER=your_smtp_user@example.com
EMAIL_PASS=your_smtp_password
# Optional SMTP host/port/secure
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# Or set EMAIL_SERVICE=gmail (nodemailer will use the service)

# Email from address shown to recipients
EMAIL_FROM=Car Rental <no-reply@yourdomain.com>

# Server port
PORT=3000